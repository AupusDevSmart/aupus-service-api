# === aupus-service-api - exemplo de configuracao ===
# Copie este arquivo para .env e preencha com valores reais do seu ambiente.
# .env nunca deve ser commitado. Em producao ele vive apenas no servidor.

# === Banco de dados ===
# Dev local (Docker postgres:15-alpine na porta 5433):
#   postgresql://postgres:postgres@localhost:5433/aupus_local?schema=public&connection_limit=10&pool_timeout=20
# Producao: ajustar usuario/senha/host conforme servidor.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public&connection_limit=10&pool_timeout=20"

# === Servidor ===
NODE_ENV=development                 # development | production
PORT=3000
LOG_LEVEL=debug                      # debug | info | warn | error

# === CORS ===
# Lista separada por virgula com origens permitidas. Vazio = reflete qualquer origem (uso apenas em dev).
# Producao: CORS_ORIGIN=https://service.aupusenergia.com.br,https://nexon.aupusenergia.com.br
CORS_ORIGIN=

# === Frontend (usado em links de email, redirects, etc.) ===
FRONTEND_URL=http://localhost:5173

# === JWT ===
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE-ME
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# === MQTT broker ===
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=root
MQTT_PASSWORD=CHANGE-ME
# production = conecta e SALVA no banco | development = conecta sem salvar | disabled = nao conecta
# IMPORTANTE: apenas UMA instancia pode rodar com MQTT_MODE=production por vez.
MQTT_MODE=disabled
MQTT_LOG_LEVEL=normal                # minimal | normal | verbose
INSTANCE_ID=local-dev

# === Redis (buffer MQTT) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === SMTP (emails transacionais) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=CHANGE-ME
SMTP_FROM_NAME=Aupus
SMTP_FROM_EMAIL=noreply@example.com

# === Sentry (opcional) ===
SENTRY_DSN=
